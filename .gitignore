# Local logs and generated runtime artifacts
logs/*
!logs/.gitkeep
generated/*
!generated/.gitkeep
!generated/*.yaml
workspace/*
!workspace/.gitkeep
knowledge-base/.index/
.cache/

# Local environment files
.env
.env.*
*.local
.tools/
cover.out

# Kubernetes local credentials or configs
kubeconfig
*.kubeconfig

# OS/editor files
.DS_Store
Thumbs.db
.vscode/

# Python local cache
__pycache__/
*.pyc
